{
  "name": "ivy-language",
  "displayName": "Ivy Language",
  "description": "Language support for Ivy formal specification files (.ivy) — syntax highlighting, LSP client, snippets",
  "version": "0.10.0",
  "publisher": "panther-ivy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElNiak/vscode-ivy"
  },
  "icon": "icons/ivy-extension-icon.png",
  "homepage": "https://github.com/ElNiak/vscode-ivy#readme",
  "galleryBanner": {
    "color": "#1a1f3a",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://github.com/ElNiak/vscode-ivy/actions/workflows/ci.yml/badge.svg",
      "href": "https://github.com/ElNiak/vscode-ivy/actions/workflows/ci.yml",
      "description": "CI"
    }
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "ivy",
    "formal verification",
    "protocol specification",
    "QUIC",
    "PANTHER"
  ],
  "activationEvents": [
    "onLanguage:ivy"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ivy-monitor",
          "title": "Ivy LSP",
          "icon": "icons/ivy-dark.png"
        }
      ]
    },
    "views": {
      "ivy-monitor": [
        {
          "id": "ivyMonitor",
          "name": "Monitor",
          "type": "tree"
        },
        {
          "id": "ivyRequirements",
          "name": "Requirements",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "ivy.installServer",
        "title": "Ivy: Install Language Server"
      },
      {
        "command": "ivy.installFullSupport",
        "title": "Ivy: Install Full Support (z3)"
      },
      {
        "command": "ivy.resetServer",
        "title": "Ivy: Reset Language Server Installation"
      },
      {
        "command": "ivy.verify",
        "title": "Ivy: Verify",
        "icon": "$(check-all)"
      },
      {
        "command": "ivy.compile",
        "title": "Ivy: Compile",
        "icon": "$(gear)"
      },
      {
        "command": "ivy.showModel",
        "title": "Ivy: Show Model Info",
        "icon": "$(info)"
      },
      {
        "command": "ivy.cancelOperation",
        "title": "Ivy: Cancel Running Operation"
      },
      {
        "command": "ivy.setActiveTest",
        "title": "Ivy: Set Active Test",
        "icon": "$(beaker)"
      },
      {
        "command": "ivy.listTests",
        "title": "Ivy: List Available Tests",
        "icon": "$(list-unordered)"
      },
      {
        "command": "ivy.openDashboard",
        "title": "Ivy: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "ivy.reindexWorkspace",
        "title": "Ivy: Re-index Workspace",
        "icon": "$(refresh)"
      },
      {
        "command": "ivy.clearCache",
        "title": "Ivy: Clear Cache",
        "icon": "$(trash)"
      },
      {
        "command": "ivy.checkForUpdates",
        "title": "Ivy: Check for LSP Updates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "ivy.refreshMonitor",
        "title": "Ivy: Refresh Monitor",
        "icon": "$(refresh)"
      },
      {
        "command": "ivy.editIncludePaths",
        "title": "Ivy: Edit Include Paths",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ivy.editExcludePaths",
        "title": "Ivy: Edit Exclude Paths",
        "icon": "$(folder)"
      },
      {
        "command": "ivy.showOutput",
        "title": "Ivy: Show Server Output",
        "icon": "$(output)"
      },
      {
        "command": "ivy.toggleDebugLog",
        "title": "Ivy: Toggle Debug Logging",
        "icon": "$(bug)"
      },
      {
        "command": "ivy.openModelVisualization",
        "title": "Ivy: Open Model Visualization",
        "icon": "$(graph)"
      },
      {
        "command": "ivy.showActionRequirements",
        "title": "Ivy: Show Action Requirements",
        "icon": "$(list-tree)"
      },
      {
        "command": "ivy.refreshRequirements",
        "title": "Ivy: Refresh Requirements",
        "icon": "$(refresh)"
      }
    ],
    "submenus": [
      {
        "id": "ivy.submenu",
        "label": "Ivy"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "ivy.submenu",
          "when": "editorLangId == ivy",
          "group": "ivy"
        }
      ],
      "explorer/context": [
        {
          "submenu": "ivy.submenu",
          "when": "resourceExtname == .ivy",
          "group": "ivy"
        }
      ],
      "view/title": [
        {
          "command": "ivy.refreshMonitor",
          "when": "view == ivyMonitor",
          "group": "navigation"
        },
        {
          "command": "ivy.openDashboard",
          "when": "view == ivyMonitor",
          "group": "navigation"
        },
        {
          "command": "ivy.refreshRequirements",
          "when": "view == ivyRequirements",
          "group": "navigation"
        },
        {
          "command": "ivy.openModelVisualization",
          "when": "view == ivyRequirements",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ivy.reindexWorkspace",
          "when": "viewItem == indexing || viewItem == indexingItem",
          "group": "inline"
        },
        {
          "command": "ivy.clearCache",
          "when": "viewItem == indexing || viewItem == indexingItem"
        },
        {
          "command": "ivy.cancelOperation",
          "when": "viewItem == activeOperation",
          "group": "inline"
        },
        {
          "command": "ivy.editIncludePaths",
          "when": "viewItem == configItem"
        },
        {
          "command": "ivy.editExcludePaths",
          "when": "viewItem == configItem"
        }
      ],
      "ivy.submenu": [
        {
          "command": "ivy.verify",
          "group": "1_actions"
        },
        {
          "command": "ivy.compile",
          "group": "1_actions"
        },
        {
          "command": "ivy.showModel",
          "group": "2_info"
        },
        {
          "command": "ivy.setActiveTest",
          "group": "1_actions"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ivy.verify",
        "key": "ctrl+shift+f5",
        "mac": "cmd+shift+f5",
        "when": "editorLangId == ivy && editorTextFocus"
      },
      {
        "command": "ivy.compile",
        "key": "ctrl+shift+f6",
        "mac": "cmd+shift+f6",
        "when": "editorLangId == ivy && editorTextFocus"
      },
      {
        "command": "ivy.showModel",
        "key": "ctrl+shift+f7",
        "mac": "cmd+shift+f7",
        "when": "editorLangId == ivy && editorTextFocus"
      },
      {
        "command": "ivy.setActiveTest",
        "key": "ctrl+shift+f8",
        "mac": "cmd+shift+f8",
        "when": "editorLangId == ivy && editorTextFocus"
      }
    ],
    "languages": [
      {
        "id": "ivy",
        "aliases": [
          "Ivy",
          "ivy"
        ],
        "extensions": [
          ".ivy"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ivy-light.png",
          "dark": "./icons/ivy-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ivy",
        "scopeName": "source.ivy",
        "path": "./syntaxes/ivy.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ivy",
        "path": "./snippets/ivy.json"
      }
    ],
    "configuration": {
      "title": "Ivy Language",
      "properties": {
        "ivy.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter used to run the Ivy LSP server. Leave empty for auto-detection."
        },
        "ivy.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Ivy Language Server for diagnostics, completion, and navigation."
        },
        "ivy.lsp.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments passed to the Ivy LSP server process."
        },
        "ivy.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace level for communication between VSCode and the Ivy LSP server."
        },
        "ivy.lsp.managedInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install the Ivy LSP server into a managed environment when not found."
        },
        "ivy.lsp.managedInstallPath": {
          "type": "string",
          "default": "",
          "description": "Custom path for the managed LSP install. Leave empty for ~/.ivy-lsp/."
        },
        "ivy.lsp.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR"
          ],
          "default": "INFO",
          "description": "Log level for the Ivy LSP server process. Set to DEBUG for verbose diagnostics."
        },
        "ivy.lsp.maxRestartCount": {
          "type": "integer",
          "default": 5,
          "minimum": -1,
          "description": "Maximum number of server restarts within the restart window before giving up. Set to -1 for unlimited restarts."
        },
        "ivy.lsp.restartWindow": {
          "type": "integer",
          "default": 180,
          "minimum": 10,
          "description": "Time window in seconds for counting server restarts. Only applies when maxRestartCount is not -1."
        },
        "ivy.lsp.includePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Directories to include in workspace indexing (relative to workspace root). When set, only these directories are scanned for .ivy files. Leave empty to scan the entire workspace."
        },
        "ivy.lsp.excludePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "submodules",
            "test"
          ],
          "description": "Directories to exclude from workspace indexing (relative to workspace root). The LSP stages non-excluded files into a flat directory for unambiguous include resolution. Add 'apt' to skip APT models. Exclusions apply within included paths."
        },
        "ivy.lsp.parseWorkers": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 16,
          "description": "Number of parallel worker processes for deep indexing. 0 = auto (half CPU cores), 1 = serial."
        },
        "ivy.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline code lenses for requirement counts, state variable reads, and property dependencies above monitor blocks."
        },
        "ivy.codeLens.rfcCoverage": {
          "type": "boolean",
          "default": true,
          "description": "Show workspace-level RFC coverage summary code lenses on files with bracket tag annotations."
        },
        "ivy.tools.verifyTimeout": {
          "type": "number",
          "default": 120,
          "description": "Timeout in seconds for verification."
        },
        "ivy.tools.compileTimeout": {
          "type": "number",
          "default": 300,
          "description": "Timeout in seconds for compilation."
        },
        "ivy.tools.autoSaveBeforeAction": {
          "type": "boolean",
          "default": true,
          "description": "Auto-save the active file before running Ivy commands."
        },
        "ivy.testScope.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable test scope management. Shows active test in the status bar and enables automatic scope detection."
        },
        "ivy.testScope.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically set the active test when opening a test file. The scope stays sticky when switching to non-test files."
        },
        "ivy.testScope.showNctLabels": {
          "type": "boolean",
          "default": true,
          "description": "Show NCT classification tags ([ASSUMPTION]/[GUARANTEE]) in code lens labels when a test scope is active."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js --production && node esbuild.webview.js --production",
    "bundle:dev": "node esbuild.js && node esbuild.webview.js",
    "bundle:webview": "node esbuild.webview.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npx mocha out/test/unit/**/*.test.js"
  },
  "dependencies": {
    "cytoscape": "^3.33.1",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
